# LLM + vision inference (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key

# Supabase pgvector — Transaction pooler URL (port 6543, not 5432)
# For langchain-postgres (SQLAlchemy) — requires +psycopg scheme
SUPABASE_CONNECTION_STRING=postgresql+psycopg://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres
# For psycopg.connect() — plain postgresql:// scheme
SUPABASE_DB_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# Supabase project credentials (https://supabase.com/dashboard/project/_/settings/api)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key  # use service_role, not anon key

# HuggingFace token for higher rate limits when downloading all-MiniLM-L6-v2
# Optional — works without it but may be rate limited on first run
HF_TOKEN=your_huggingface_token
